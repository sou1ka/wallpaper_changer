{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all"
  },
  "productName": "wallpaper_changer",
  "mainBinaryName": "wallpaper_changer",
  "version": "1.1.0",
  "identifier": "com.sou1ka.tauri.wallpaperchanger",
  "plugins": {},
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "wallpaper_changer",
        "fullscreen": false,
        "resizable": true,
        "title": "Wallpaper Changer",
        "width": 920,
        "height": 680,
        "minWidth": 400,
        "minHeight": 300,
        "transparent": true,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "assetProtocol": {
        "scope": [
          "**"
        ],
        "enable": true
      },
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; font-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  }
}
